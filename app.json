{
  "expo": {
    "name": "Click A Cursor",
    "slug": "Click A Cursor",
    "version": "1.0.0",

    "orientation": "portrait",
    "userInterfaceStyle": "dark",

    "icon": "./assets/images/icon.png",
    "scheme": "goldencursor",

    "android": {
      "package": "com.jax.goldencursor",
      "versionCode": 1,

      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#000000"
      }
    },

    "ios": {
      "supportsTablet": true
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ]
    ],

    "extra": {
      "appName": "Golden Cursor"
    }
  }
}
